#!/usr/bin/env bash
#MISE description="Check for divergence between repo skills and install paths"
set -euo pipefail

echo "→ checking skill eval JSON files..."
mise run check-skill-json

echo "→ checking installed skill directories..."

fail=0
for skill_dir in skills/*/; do
  name=$(basename "$skill_dir")
  src_dir="${skill_dir%/}"
  claude_path="$HOME/.claude/skills/$name"
  agents_path="$HOME/.agents/skills/$name"
  skill_fail=0

  if [ ! -d "$claude_path" ]; then
    echo "  ⚠ $name: not installed at ~/.claude/skills/"
  elif ! diff -qr --exclude '.DS_Store' "$src_dir" "$claude_path" > /dev/null 2>&1; then
    echo "  ✗ $name: diverged at ~/.claude/skills/"
    skill_fail=1
  fi

  if [ ! -d "$agents_path" ]; then
    echo "  ⚠ $name: not installed at ~/.agents/skills/"
  elif ! diff -qr --exclude '.DS_Store' "$src_dir" "$agents_path" > /dev/null 2>&1; then
    echo "  ✗ $name: diverged at ~/.agents/skills/"
    skill_fail=1
  fi

  if [ $skill_fail -eq 0 ] && [ -d "$claude_path" ] && [ -d "$agents_path" ]; then
    echo "  ✓ $name"
  fi

  fail=$((fail + skill_fail))
done

if [ $fail -gt 0 ]; then
  echo ""
  echo "✗ $fail skill(s) have diverged install paths. Push aborted."
  exit 1
fi
echo "✓ all skills in sync"
